{
  "name": "@livedocs/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3 && node ../../scripts/rebuild-store-sqlite.mjs",
    "test:e2e": "electron-vite build && playwright test"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@ai-sdk/google": "^2.0.0",
    "@ai-sdk/openai": "^2.0.0",
    "@ai-sdk/openai-compatible": "^1.0.0",
    "@livedocs/ai": "workspace:*",
    "@livedocs/analysis": "workspace:*",
    "@livedocs/generators": "workspace:*",
    "@livedocs/pipeline": "workspace:*",
    "@livedocs/store": "workspace:*",
    "ai": "^5.0.0",
    "better-sqlite3": "^12.1.0",
    "chokidar": "^4.0.3",
    "diff": "^7.0.0",
    "es-module-lexer": "^1.7.0",
    "ignore": "^7.0.0",
    "mermaid": "^11.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.0",
    "@playwright/test": "^1.54.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^7.0.0",
    "@types/mdast": "^4.0.4",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "^38.0.0",
    "electron-vite": "^4.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  }
}
